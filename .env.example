# Copy to .env and adjust.  Never commit the real .env.

# Required in production.  Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=

# "1" enables Django debug pages and serves /media/ from the dev server.
# Must be "0" in production.
DJANGO_DEBUG=1

# Comma-separated hostnames.  Ignored while DJANGO_DEBUG=1.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Max upload size in megabytes.
MAX_UPLOAD_MB=200
